<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project: CODEX - Public Policy</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700&family=Noto+Sans+KR:wght@300;400;700&display=swap');

        :root {
            --midnight-blue: #0A192F;
            --antique-ivory: #FDFBF7;
            --champagne-gold: #D4AF37;
            --glass-bg: rgba(253, 251, 247, 0.05);
        }

        body {
            background-color: var(--midnight-blue);
            color: var(--antique-ivory);
            font-family: 'Noto Sans KR', sans-serif;
            scroll-behavior: smooth;
            overflow-x: hidden;
        }

        h1, h2, h3, .serif {
            font-family: 'Noto Serif KR', serif;
        }

        /* 수직 가름끈 디자인 */
        .bookmark-line {
            position: fixed;
            left: 50px;
            top: 0;
            width: 1px;
            height: 100vh;
            background: linear-gradient(to bottom, transparent, var(--champagne-gold), transparent);
            z-index: 10;
            opacity: 0.5;
        }

        /* 글래스모피즘 카드 */
        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(212, 175, 55, 0.15);
            border-radius: 16px;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            opacity: 0;
            transform: translateY(20px);
        }

        .glass-card:hover {
            border-color: var(--champagne-gold);
            background: rgba(253, 251, 247, 0.08);
            transform: translateY(-8px);
            box-shadow: 0 10px 30px -10px rgba(0,0,0,0.5);
        }

        /* 아티클 제목 스타일 */
        .article-title {
            display: flex;
            align-items: baseline;
            gap: 12px;
            margin-bottom: 2rem;
        }

        .article-no {
            color: var(--champagne-gold);
            font-size: 0.9rem;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
        }

        /* 탭 시스템 애니메이션 */
        .tab-content {
            display: none;
            animation: fadeIn 0.5s ease-out;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* 이미지 레이아웃 기반 탭 스타일 */
        .tab-button {
            width: 100%;
            padding: 14px 20px;
            margin-bottom: 12px;
            border-radius: 12px;
            text-align: left;
            font-size: 1.1rem;
            transition: all 0.3s;
            border: 1px solid rgba(212, 175, 55, 0.2);
            background: rgba(255, 255, 255, 0.03);
            color: rgba(253, 251, 247, 0.6);
            cursor: pointer;
        }

        .tab-button.active {
            background: rgba(253, 251, 247, 0.08);
            border: 2px solid var(--champagne-gold);
            color: var(--antique-ivory);
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.2);
            font-weight: 700;
        }

        /* 섹션 패딩 */
        section {
            padding: 100px 5% 100px 100px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        /* 차트 애니메이션 */
        .bar-grow {
            transform-origin: left;
            animation: growRight 1.5s ease-out forwards;
        }

        @keyframes growRight {
            from { scale: 0 1; }
            to { scale: 1 1; }
        }

        /* 커스텀 스크롤바 */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--midnight-blue); }
        ::-webkit-scrollbar-thumb { background: var(--champagne-gold); border-radius: 3px; }

        .fade-up {
            animation: fadeUp 1.2s ease-out forwards;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .hero-line {
            width: 0;
            height: 2px;
            background: var(--champagne-gold);
            margin: 2rem auto;
            animation: growLine 1.5s ease-out 0.5s forwards;
        }

        @keyframes growLine {
            from { width: 0; }
            to { width: 150px; }
        }

        /* 아이콘 박스 스타일 */
        .icon-box {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(214, 175, 55, 0.1);
            border: 1px solid rgba(214, 175, 55, 0.3);
            border-radius: 12px;
            color: var(--champagne-gold);
            margin-bottom: 1.25rem;
            transition: all 0.3s ease;
        }

        .glass-card:hover .icon-box {
            background: var(--champagne-gold);
            color: var(--midnight-blue);
            transform: scale(1.1);
        }
    </style>
</head>

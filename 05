    <footer class="p-12 text-center border-t border-white/5 opacity-40">
        <p class="text-xs tracking-[0.2em] uppercase mb-4">Project CODEX - Public Policy Administration</p>
        <p class="serif italic text-[10px]">"정의는 복잡한 계산 끝에 나오는 가장 단순한 결과다"</p>
        <div class="mt-8 text-[10px]">© 2024 | All Rights Reserved in the Book of Law</div>
    </footer>

    <!-- Scripts -->
    <script>
        const descriptions = {
            'enterprise': '사회적 가치 실현과 효율성의 균형을 탐구합니다.',
            'servant': '국가 행정의 기틀과 공익의 수호에 대해 배웁니다.',
            'lawschool': '법적 사고력(Legal Mind)을 바탕으로 정의를 구현합니다.'
        };

        function showTab(tabId, el) {
            // Update Tab Buttons
            document.querySelectorAll('.tab-button').forEach(btn => btn.classList.remove('active'));
            el.classList.add('active');

            // Update Content
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');

            // Update Description
            document.getElementById('tab-desc').innerText = descriptions[tabId];
        }

        const observerOptions = { threshold: 0.2 };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const id = entry.target.getAttribute('id');
                    document.querySelectorAll('nav a').forEach(a => {
                        a.classList.remove('bg-[#D4AF37]');
                        if (a.getAttribute('href') === '#' + id) a.classList.add('bg-[#D4AF37]');
                    });
                    
                    const cards = entry.target.querySelectorAll('.glass-card');
                    cards.forEach((card, index) => {
                        setTimeout(() => {
                            card.style.opacity = "1";
                            card.style.transform = "translateY(0)";
                        }, index * 150);
                    });
                }
            });
        }, observerOptions);

        document.querySelectorAll('section').forEach(section => observer.observe(section));
    </script>
</body>
</html>
